# Program to find average marks and topper marks

# Taking number of students
n = int(input("Enter number of students: "))

# Creating an empty list
marks = []

# Taking marks input from user
for i in range(n):
    m = float(input(f"Enter marks of student {i+1}: "))
    marks.append(m)
